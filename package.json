{
  "name": "tsn-website-blog",
  "version": "1.2.1",
  "description": "The Strivers' Network",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "ci": "payload migrate && pnpm build"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@google-analytics/data": "^5.2.2",
    "@lexical/link": "^0.41.0",
    "@lexical/list": "^0.41.0",
    "@lexical/react": "^0.41.0",
    "@lexical/rich-text": "^0.41.0",
    "@lexical/selection": "^0.41.0",
    "@lexical/utils": "^0.41.0",
    "@payloadcms/admin-bar": "^3.84.1",
    "@payloadcms/db-vercel-postgres": "^3.84.1",
    "@payloadcms/email-resend": "^3.84.1",
    "@payloadcms/live-preview-react": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/plugin-form-builder": "^3.84.1",
    "@payloadcms/plugin-nested-docs": "^3.84.1",
    "@payloadcms/plugin-redirects": "^3.84.1",
    "@payloadcms/plugin-search": "^3.84.1",
    "@payloadcms/plugin-seo": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@payloadcms/storage-vercel-blob": "^3.84.1",
    "@payloadcms/ui": "^3.84.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "bufferutil": "^4.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "embla-carousel-react": "^8.6.0",
    "geist": "^1.7.0",
    "graphql": "^16.14.0",
    "lexical": "^0.41.0",
    "lucide-react": "^0.378.0",
    "motion": "^12.38.0",
    "next": "15.5.18",
    "next-sitemap": "^4.2.3",
    "payload": "^3.84.1",
    "prism-react-renderer": "^2.4.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-hook-form": "7.45.4",
    "recharts": "^3.8.1",
    "shadcn": "^3.8.5",
    "sharp": "0.34.2",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "utf-8-validate": "^6.0.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "1.56.1",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "16.3.0",
    "@types/escape-html": "^1.0.4",
    "@types/node": "22.5.4",
    "@types/react": "19.2.1",
    "@types/react-dom": "19.2.1",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "^10.5.0",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.4.7",
    "jsdom": "26.1.0",
    "playwright": "1.56.1",
    "playwright-core": "1.56.1",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver",
      "bufferutil",
      "utf-8-validate"
    ],
    "overrides": {
      "ws": "^8.18.0"
    }
  },
  "packageManager": "pnpm@10.20.0"
}